# Local dev env — copy to .env.local, then `source .env.local` before
# `go run cmd/server/main.go`. NOT committed.
#
# Differences vs the production .env:
#   - DATABASE_URL uses localhost:5435 instead of the docker network "db:5432"
#   - Paths use the repo-local docgen/ instead of /app/docgen/
#   - TESSDATA_PREFIX points to the repo-local Russian traineddata
#   - APP_ENV=dev lets the cookie layer send non-Secure cookies on HTTP

export DATABASE_URL="postgres://fuji:fuji123@localhost:5435/fujitravel?sslmode=disable"
export ANTHROPIC_API_KEY="sk-ant-..."
export APP_SECRET="$(openssl rand -base64 32)"
export APP_ENV="dev"

export UPLOADS_DIR="./uploads"
export DOCGEN_SCRIPT="../docgen/generate.py"
export REDACT_SCAN_SCRIPT="../docgen/redact_scan.py"
export DOCGEN_PDF_TEMPLATE="../templates/anketa_template.pdf"
export DOCGEN_TEMPLATES_DIR="../templates"

# Tesseract finds Russian traineddata here. Populated via:
#   mkdir -p docgen/tessdata && \
#   curl -fL -o docgen/tessdata/rus.traineddata \
#     https://github.com/tesseract-ocr/tessdata_best/raw/main/rus.traineddata && \
#   curl -fL -o docgen/tessdata/eng.traineddata \
#     https://github.com/tesseract-ocr/tessdata_best/raw/main/eng.traineddata
export TESSDATA_PREFIX="$(pwd)/../docgen/tessdata/"

# AI audit log retention (days). 0 disables the purge loop.
export AI_LOG_RETENTION_DAYS="30"
