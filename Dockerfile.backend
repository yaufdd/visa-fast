# ── Build stage ────────────────────────────────────────────────────────────────
FROM golang:1.25-alpine AS builder

WORKDIR /src
COPY backend/go.mod backend/go.sum ./
RUN go mod download

COPY backend/ ./
RUN CGO_ENABLED=0 go build -o /app/server ./cmd/server

# ── Runtime stage ─────────────────────────────────────────────────────────────
FROM python:3.12-slim

# System deps:
#   - pdftk-java : PDF form filling (fillpdf dependency, for anketa)
#   - tesseract  : local OCR used by redact_scan.py to find the name region
#                  on ticket/voucher scans BEFORE they are sent to Anthropic
#   - poppler-utils: pdf2image dependency (PDF → image for OCR)
#   - libgl1 libglib2.0-0 : opencv-python-headless runtime dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        pdftk-java \
        tesseract-ocr tesseract-ocr-rus tesseract-ocr-eng \
        poppler-utils libgl1 libglib2.0-0 && \
    rm -rf /var/lib/apt/lists/*

# Python dependencies for docgen + redact_scan.py
RUN pip install --no-cache-dir \
    python-docx fillpdf \
    pytesseract==0.3.13 pdf2image==1.17.0 \
    pillow==11.1.0 opencv-python-headless==4.10.0.84

WORKDIR /app

# Go binary
COPY --from=builder /app/server ./server

# Migrations
COPY backend/migrations/ ./migrations/

# Python docgen script
COPY docgen/ ./docgen/

# Document templates (.docx + .pdf)
COPY templates/ ./templates/

ENV PORT=8081
ENV UPLOADS_DIR=/app/uploads
ENV DOCGEN_SCRIPT=/app/docgen/generate.py
ENV REDACT_SCAN_SCRIPT=/app/docgen/redact_scan.py
ENV MIGRATIONS_DIR=/app/migrations
ENV DOCGEN_TEMPLATES_DIR=/app/templates
ENV DOCGEN_PDF_TEMPLATE=/app/templates/anketa_template.pdf

EXPOSE 8081

CMD ["./server"]
